/* Shared VERSIONINFO template. CMake configures one .rc per binary from this
 * (@RTV_RC_*@ placeholders) so descriptions differ but version/icon stay in
 * lockstep. Add new resources (manifests, cursors) as separate .rc inputs. */
#include <winver.h>

1 ICON "@RTV_RC_ICON@"

1 VERSIONINFO
FILEVERSION     @RTV_RC_VER_COMMA@
PRODUCTVERSION  @RTV_RC_VER_COMMA@
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"
    BEGIN
      VALUE "CompanyName",      "retriever project"
      VALUE "FileDescription",  "@RTV_RC_DESC@"
      VALUE "FileVersion",      "@RTV_RC_VER@"
      VALUE "InternalName",     "@RTV_RC_NAME@"
      VALUE "OriginalFilename", "@RTV_RC_NAME@.exe"
      VALUE "ProductName",      "retriever"
      VALUE "ProductVersion",   "@RTV_RC_VER@"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x409, 1200
  END
END
